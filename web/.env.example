# Server-side fallback used by the Muapi proxy route when a request has no
# x-api-key header. Optional: clients can still supply their own key per-request.
MUAPI_API_KEY=your_muapi_api_key_here

# Comma-separated list of origins allowed to call the proxy cross-origin
# (e.g. https://example.com,https://app.example.com), or "*" for any origin.
# Leave unset to keep the route same-origin only. Be cautious combining "*"
# with MUAPI_API_KEY above, since it lets any site use your server-side key.
CORS_ALLOWED_ORIGINS=
